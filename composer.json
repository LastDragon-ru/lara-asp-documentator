{
  "name": "lastdragon-ru/lara-asp-documentator",
  "homepage": "https://github.com/LastDragon-ru/php-packages",
  "description": "Provides various utilities for documentation generation such as Markdown Preprocessor, Requirements Dumper and more.",
  "readme": "README.md",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "documetation",
    "utils",
    "laravel-package",
    "laravel",
    "markdown",
    "preprocessor",
    "php"
  ],
  "support": {
    "issues": "https://github.com/LastDragon-ru/php-packages/issues",
    "source": "https://github.com/LastDragon-ru/php-packages",
    "forum": "https://github.com/LastDragon-ru/php-packages/discussions"
  },
  "require": {
    "php": "^8.4|^8.5",
    "ext-filter": "*",
    "ext-intl": "*",
    "ext-mbstring": "*",
    "composer/semver": "^3.2.0",
    "illuminate/contracts": "^13.0.0",
    "illuminate/console": "^13.0.0",
    "illuminate/process": "^13.0.0",
    "illuminate/support": "^13.0.0",
    "league/commonmark": "^2.8.2",
    "league/config": "^1.1.1",
    "nikic/php-parser": "^5.7.0",
    "phpstan/phpdoc-parser": "^2.0.0",
    "psr/event-dispatcher": "^1.0.0",
    "symfony/console": "^8.0.4",
    "symfony/filesystem": "^8.0.0",
    "symfony/finder": "^8.0.0",
    "symfony/polyfill-php85": "^1.33.0",
    "symfony/serializer": "^8.0.0",
    "lastdragon-ru/glob-matcher": "self.version",
    "lastdragon-ru/lara-asp-core": "self.version",
    "lastdragon-ru/lara-asp-formatter": "self.version",
    "lastdragon-ru/lara-asp-serializer": "self.version",
    "lastdragon-ru/graphql-printer": "self.version",
    "lastdragon-ru/path": "self.version"
  },
  "require-dev": {
    "ext-xmlwriter": "*",
    "lastdragon-ru/lara-asp-testing": "self.version",
    "lastdragon-ru/phpunit-extensions": "self.version",
    "mockery/mockery": "^1.6.6",
    "orchestra/testbench": "^11.0.0",
    "phpunit/phpunit": "^13.0.0",
    "webonyx/graphql-php": "^15.4.0"
  },
  "autoload": {
    "psr-4": {
      "LastDragon_ru\\LaraASP\\Documentator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LastDragon_ru\\LaraASP\\Documentator\\Docs\\": "docs"
    },
    "exclude-from-classmap": [
      "docs/"
    ]
  },
  "conflict": {
    "thecodingmachine/safe": "<3.0.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "LastDragon_ru\\LaraASP\\Documentator\\PackageProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
